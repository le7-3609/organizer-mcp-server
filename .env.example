# Environment Configuration for Organizer MCP Server
# Copy this file to .env and customize as needed

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Maximum file size to read (in bytes)
# Default: 50000 (50KB)
MAX_FILE_READ_SIZE=50000

# Minimum file size for duplicate detection (in bytes)
# Default: 1024 (1KB)
MIN_DUPLICATE_SIZE=1024

# Server name for MCP protocol
SERVER_NAME=organizer-mcp-server

# Enable detailed logging to file
LOG_TO_FILE=true

# Log file path (relative to project root)
LOG_FILE_PATH=organizer-mcp-server.log
